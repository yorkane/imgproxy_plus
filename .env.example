PLUS_DATA_ROOT=/data
PLUS_RAMDISK_PATH=/mnt/ramdisk
PLUS_HTTP_PORT=8080
PLUS_LOG_LEVEL=warn
PLUS_URL_PREFIX=/gallery
AUTH_USER=admin:imgproxy3.14
AUTH_IP_WHITELIST=192.168.1.0/24,172.16.0.0/12,127.0.0.1
PLUS_LOCAL_PATH=/data/plus
ZIP_EXTS=zip,cbz
ZIPFS_TRANSPARENT=true
API_PAGE_SIZE_MAX=200
FILEAPI_DISABLE=false

# ---- imgproxy 内部配置 ----
IMGPROXY_BIND=:8081
IMGPROXY_LOCAL_FILESYSTEM_ROOT=/
IMGPROXY_KEY=
IMGPROXY_SALT=
IMGPROXY_SECRET=
IMGPROXY_QUALITY=80
IMGPROXY_AUTO_WEBP=true
IMGPROXY_LOG_LEVEL=warn
IMGPROXY_MALLOC=jemalloc

# ---- Gallery Archive 自动归档 ----
GALLERY_AUTO_ENABLED=false
GALLERY_SCAN_DIR=/data/aria2/data/completed
GALLERY_ARCHIVE_DIR=/data/archived
GALLERY_SCAN_INTERVAL=1800
GALLERY_ARCHIVE_FMT=webp
GALLERY_ARCHIVE_W=2560
GALLERY_ARCHIVE_H=2560
GALLERY_ARCHIVE_FIT=cover
GALLERY_ARCHIVE_Q=90
GALLERY_ARCHIVE_MIN_KB=10
GALLERY_ARCHIVE_MIN_CHAPTER=5
GALLERY_ARCHIVE_CONCURRENCY=0
GALLERY_COMPLETE_WEBHOOK_URL=
